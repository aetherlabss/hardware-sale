rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'admin@hardwaresales.co.mz' ||
        (isEmailVerified() && (
          request.auth.token.email == 'gabriel.vieira.jamal@gmail.com' ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        ))
      ); 
    }
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // 0.2 Validation Blueprints

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'status', 'images', 'desc', 'tags', 'specs', 'createdAt', 'updatedAt'])
        && data.keys().size() == 10
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.status is string && data.status in ["stock", "encomenda", "na_box", "usados"]
        && data.images is list && data.images.size() > 0 && data.images.size() <= 10 && data.images[0] is string
        && data.desc is string && data.desc.size() <= 5000
        && data.tags is list && data.tags.size() <= 20
        && data.specs is map
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidProductUpdate(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.status is string && data.status in ["stock", "encomenda", "na_box", "usados"]
        && data.images is list && data.images.size() > 0 && data.images.size() <= 10 && data.images[0] is string
        && data.desc is string && data.desc.size() <= 5000
        && data.tags is list && data.tags.size() <= 20
        && data.specs is map
        && data.updatedAt == request.time;
    }

    // 1. Products Collection
    match /products/{productId} {
      allow list: if true;
      allow get: if isValidId(productId);
      
      allow create: if isAdmin()
                    && isValidId(productId)
                    && isValidProduct(incoming());
                    
      allow update: if isAdmin()
                    && isValidId(productId)
                    && isValidProductUpdate(incoming())
                    && incoming().diff(existing()).affectedKeys().hasAny(['name', 'price', 'category', 'status', 'images', 'desc', 'tags', 'specs', 'updatedAt'])
                    && incoming().createdAt == existing().createdAt;
      
      allow delete: if isAdmin() && isValidId(productId);
    }

    // 2. Admins Collection
    match /admins/{adminId} {
      // Only the bootstrapped admin can do CRUD on this, because exists() uses uid, but you can only be an admin if you're already in it or match email.
      allow read: if isAdmin();
      
      function isValidAdmin(data) {
        return data.keys().hasAll(['email', 'isAdmin', 'createdAt'])
            && data.keys().size() == 3
            && data.email is string && data.email.size() > 0 && data.email.size() <= 200
            && data.isAdmin is bool && data.isAdmin == true
            && data.createdAt == request.time;
      }
      
      allow create: if isAdmin() && isValidId(adminId) && isValidAdmin(incoming());
      
      allow update: if false; // Admins are immutable, just delete and recreate
      allow delete: if isAdmin() && isValidId(adminId);
    }
    
    // 3. Analytics Events Collection
    match /analytics_events/{eventId} {
      allow read, list: if isAdmin();
      
      function isValidEvent(data) {
        return data.keys().hasAll(['type', 'path', 'sessionId', 'timestamp'])
          && (data.keys().size() == 4 || (data.keys().size() == 5 && data.keys().hasAll(['value'])))
          && data.type is string && data.type.size() > 0 && data.type.size() <= 50
          && data.path is string && data.path.size() <= 500
          && data.sessionId is string && data.sessionId.size() <= 100
          && (data.keys().hasAll(['value']) ? data.value is number : true)
          && data.timestamp == request.time;
      }
      
      allow create: if isValidId(eventId) && isValidEvent(incoming());
      allow update, delete: if false; // Events are immutable
    }

    // 4. AI Usage Collection
    match /ai_usage/{usageId} {
      allow read, list: if isAdmin();
      allow create: if true; // Any user triggering AI logs usage
      allow update, delete: if false; // Immutable logs
    }

    // 5. Admin Settings Collection
    match /admin_settings/{settingId} {
      allow read, list: if true; // Allowed so frontend can read settings if needed
      allow write: if isAdmin();
    }
  }
}
